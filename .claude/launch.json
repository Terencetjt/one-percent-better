{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Expo Go (iPhone / Android)",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["expo", "start"],
      "port": 8081
    },
    {
      "name": "Expo Web",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["expo", "start", "--web"],
      "port": 8081
    },
    {
      "name": "Expo (Dev Server)",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "start"],
      "port": 8081
    },
    {
      "name": "Expo Android",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "android"],
      "port": 8081
    },
    {
      "name": "Expo iOS",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "ios"],
      "port": 8081
    },
    {
      "name": "worldcup",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["--prefix", "../worldcup-app", "run", "dev"],
      "port": 3000,
      "autoPort": true
    }
  ]
}
